# Required: NocoDB instance URL (no trailing slash)
NOCODB_BASE_URL=https://data.example.com

# Required: API token from NocoDB → Account Settings → Tokens
NOCODB_API_TOKEN=nc_pat_...

# Optional: Default base ID to use when tools omit baseId
NOCODB_DEFAULT_BASE_ID=

# Optional: Request timeout in milliseconds (default: 30000)
NOCODB_TIMEOUT_MS=30000

# Optional: Log level — debug | info | warn | error (default: info)
NOCODB_LOG_LEVEL=info
