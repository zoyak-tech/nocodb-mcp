{
  "name": "nocodb-mcp",
  "version": "1.0.3",
  "description": "Full-coverage MCP server for NocoDB v3 — 92 tools across 19 groups. Manage schema, records, views, webhooks, links, attachments, dashboards, scripts, NocoDocs from any AI agent. stdio + HTTP transports.",
  "type": "module",
  "main": "dist/index-stdio.js",
  "bin": {
    "nocodb-mcp": "dist/index-stdio.js",
    "nocodb-mcp-http": "dist/index-http.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index-stdio.js",
    "start:http": "node dist/index-http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nocodb",
    "claude",
    "ai",
    "database",
    "no-code"
  ],
  "author": "zoyak-tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zoyak-tech/nocodb-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zoyak-tech/nocodb-mcp/issues"
  },
  "homepage": "https://github.com/zoyak-tech/nocodb-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
